<div class="max-w-md mx-auto mt-10 bg-white p-8 rounded-lg shadow-md">
  <h1 class="text-2xl font-bold text-center text-gray-800 mb-6">Login</h1>

  <% if flash[:alert] %>
  <div class="bg-red-50 border-l-4 border-red-400 p-4 mb-4">
    <div class="flex">
      <div class="flex-shrink-0">
        <svg class="h-5 w-5 text-red-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
        </svg>
      </div>
      <div class="ml-3">
        <p class="text-sm text-red-700"><%= flash[:alert] %></p>
      </div>
    </div>
  </div>
  <% end %>

  <%= form_with url: login_path, class: "space-y-6" do |form| %>
  <div class="space-y-2">
    <%= form.label :email, class: "block text-sm font-medium text-gray-700" %>
    <%= form.email_field :email, 
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            placeholder: "your@email.com",
            required: true %>
  </div>

  <div class="space-y-2">
    <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
    <%= form.password_field :password, 
            class: "w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500",
            placeholder: "••••••••",
            required: true %>
  </div>

  <div class="flex items-center justify-between">
    <div class="flex items-center">
      <%= form.check_box :remember_me, class: "h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded" %>
      <%= form.label :remember_me, class: "ml-2 block text-sm text-gray-900" %>
    </div>

    <div class="text-sm">
      <%= link_to "Forgot password?", new_password_reset_path, class: "font-medium text-blue-600 hover:text-blue-500" %>
    </div>
  </div>

  <div>
    <%= form.submit "Log In", 
            class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" %>
  </div>
  <% end %>

  <div class="mt-4 text-center text-sm text-gray-600">
    Don't have an account?
    <%= link_to "Sign up", sign_up_path, class: "font-medium text-blue-600 hover:text-blue-500" %>
  </div>
</div>