<div class="w-full max-w-4xl mx-auto px-4 py-12 bg-gray-50">
  <!-- Header -->
  <div class="text-center mb-12">
    <h1 class="text-4xl font-bold text-green-600 mb-4">Tweet Scheduler Pro</h1>
    <p class="text-xl text-gray-600">Your powerful Twitter (X) content management platform</p>
  </div>

  <!-- Overview Card -->
  <div class="bg-white rounded-xl shadow-md p-8 mb-10 border-l-4 border-green-500">
    <h2 class="text-2xl font-bold text-gray-800 mb-4">Application Overview</h2>
    <p class="text-gray-600 mb-6">
      A sophisticated Twitter scheduling platform that allows authenticated users to plan, analyze,
      and optimize their social media content with ease.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-green-50 p-5 rounded-lg">
        <h3 class="font-semibold text-green-700 mb-3">Core Features</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex items-start">
            <svg class="h-5 w-5 text-green-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Schedule tweets for future posting
          </li>
          <li class="flex items-start">
            <svg class="h-5 w-5 text-green-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Track performance metrics
          </li>
          <li class="flex items-start">
            <svg class="h-5 w-5 text-green-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Manage scheduled content
          </li>
        </ul>
      </div>

      <div class="bg-blue-50 p-5 rounded-lg">
        <h3 class="font-semibold text-blue-700 mb-3">Technical Highlights</h3>
        <ul class="space-y-2 text-gray-700">
          <li class="flex items-start">
            <svg class="h-5 w-5 text-blue-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Built with Ruby on Rails
          </li>
          <li class="flex items-start">
            <svg class="h-5 w-5 text-blue-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Secure user authentication
          </li>
          <li class="flex items-start">
            <svg class="h-5 w-5 text-blue-500 mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Data privacy protection
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Key Features Section -->
  <div class="space-y-8">
    <div class="bg-white rounded-xl shadow-md p-8">
      <div class="flex items-center mb-4">
        <div class="bg-green-100 p-3 rounded-full mr-4">
          <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15l8-8m0 0l-8-8m8 8H4" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-800">1. User Authentication & Access Control</h2>
      </div>
      <ul class="space-y-3 text-gray-600 pl-4">
        <li class="flex items-start">
          <span class="inline-block h-2 w-2 rounded-full bg-green-500 mt-2 mr-2"></span>
          Sign-in required to access any functionality
        </li>
        <li class="flex items-start">
          <span class="inline-block h-2 w-2 rounded-full bg-green-500 mt-2 mr-2"></span>
          Users can only view/edit/delete their own tweets
        </li>
        <li class="flex items-start">
          <span class="inline-block h-2 w-2 rounded-full bg-green-500 mt-2 mr-2"></span>
          Unauthorized access attempts are redirected to login
        </li>
      </ul>
    </div>

    <div class="bg-white rounded-xl shadow-md p-8">
      <div class="flex items-center mb-4">
        <div class="bg-blue-100 p-3 rounded-full mr-4">
          <svg class="h-6 w-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
          </svg>
        </div>
        <h2 class="text-2xl font-bold text-gray-800">2. Dashboard Overview</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6 mt-6">
        <div class="border-l-4 border-green-400 pl-4">
          <h3 class="font-semibold text-gray-700 mb-2">📅 Scheduled Tweet Count</h3>
          <p class="text-gray-600">Total tweets waiting to post</p>
        </div>
        <div class="border-l-4 border-blue-400 pl-4">
          <h3 class="font-semibold text-gray-700 mb-2">👁️ Impressions</h3>
          <p class="text-gray-600">Total views of published tweets</p>
        </div>
        <div class="border-l-4 border-purple-400 pl-4">
          <h3 class="font-semibold text-gray-700 mb-2">❤️ Likes</h3>
          <p class="text-gray-600">Total likes received</p>
        </div>
        <div class="border-l-4 border-yellow-400 pl-4">
          <h3 class="font-semibold text-gray-700 mb-2">📊 Engagement Rate</h3>
          <p class="text-gray-600">(Likes + Retweets) / Impressions</p>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA Section -->
  <div class="mt-12 text-center">
    <h3 class="text-2xl font-semibold text-gray-800 mb-4">Ready to boost your Twitter productivity?</h3>
    <%= link_to sign_up_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700" do %>
    Get Started Now
    <svg class="ml-3 -mr-1 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
    </svg>
    <% end %>
  </div>
</div>