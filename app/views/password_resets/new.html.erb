<!-- app/views/password_resets/new.html.erb -->
<div class="max-w-md mx-auto mt-16 p-8 bg-white rounded-lg shadow-md">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Forgot your password?</h1>

  <%= form_with url: password_resets_path, local: true, class: "space-y-6" do |form| %>
    <% if flash[:alert] %>
      <div class="p-4 bg-red-50 border-l-4 border-red-500 text-red-700">
        <p><%= flash[:alert] %></p>
      </div>
    <% end %>

    <div class="space-y-2">
      <%= form.label :email, "Email address", class: "block text-sm font-medium text-gray-700" %>
      <%= form.email_field :email, 
            class: "w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent", 
            required: true %>
    </div>

    <div class="flex items-center justify-between">
      <%= form.submit "Reset Password", 
            class: "px-4 py-2 bg-blue-600 text-white font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" %>
      <%= link_to "Back to login", login_path, 
            class: "text-sm text-blue-600 hover:text-blue-800 hover:underline" %>
    </div>
  <% end %>
</div>