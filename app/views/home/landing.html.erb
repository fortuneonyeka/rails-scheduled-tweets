<div class="w-full font-bold">
  <h1 class="text-3xl text-center justify-center">Welcome to <span class="text-green-700">Evergreen</span> Scheduled Tweets</h1>

  <div class="mt-8 max-w-md mx-auto bg-white p-8 rounded-lg shadow">
    <h2 class="text-xl font-semibold text-center mb-4">Schedule your tweets effortlessly</h2>
    <p class="text-gray-700 mb-6">Evergreen helps you automate your Twitter presence by scheduling and recycling your best content.</p>

    <div class="flex justify-center space-x-4">
      <%= link_to "Sign Up", sign_up_path, class: "px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700" %>
      <%= link_to "Log In", login_path, class: "px-4 py-2 border border-green-600 text-green-600 rounded hover:bg-green-50" %>
    </div>
  </div>
</div>